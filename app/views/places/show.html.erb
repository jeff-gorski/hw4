<h1><%= @place["name"] %></h1>

<h2>My Entries</h2>

<div class="row">
  <% for entry in @entries %>
    <div class="col-sm-6 col-md-4">
      <div class="card mb-3">
        <div class="card-body">
          <h3 class="card-title"><%= entry["title"] %></h3>
          <h6 class="card-subtitle mb-2 text-muted"><%= entry["occurred_on"] %></h6>
          <p class="card-text"><%= entry["description"] %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>

<% if @current_user != nil %>
  <p>
    <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-success">New Entry</a>
  </p>
<% else %>
  <p>You must <a href="/login">login</a> to add entries.</p>
<% end %>

<p>
  <a href="/places" class="btn btn-secondary">Back to All Places</a>
</p>